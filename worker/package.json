{
  "name": "worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app/server.js",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "verify:migration": "tsx scripts/verify-migration.ts",
    "verify:migration:snapshot": "tsx scripts/verify-migration.ts --snapshot",
    "seed:e2e": "tsx scripts/seed-e2e.ts",
    "seed:cashiers": "tsx scripts/seed-cashiers.ts",
    "seed:high-volume": "tsx scripts/seed-high-volume.ts",
    "e2e:leads": "tsx scripts/e2e-leads.ts",
    "audit:fallbacks": "tsx src/scripts/audit-landings-without-fallbacks.cli.ts",
    "seed:fallbacks": "tsx src/scripts/seed-landing-fallbacks.ts",
    "test": "find src -name '*.test.ts' -print0 | xargs -0 tsx --test",
    "reconcile:waha-webhooks": "tsx scripts/reconcile-waha-webhooks.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "altcha-lib": "^2.2.0",
    "bullmq": "^5.71.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nanoid": "^5.1.7",
    "pdf-to-png-converter": "^4.0.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "@types/express": "^4.17.23",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.20.0",
    "prisma": "^7.6.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
