generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CASHIER
  ADMIN
}

model User {
  id       String @id @default(uuid())
  username String @unique
  password String

  role Role

  admin   Admin?
  cashier Cashier?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("User")
}

model Admin {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("Admin")
}

enum CashierStatus {
  ACTIVE
  DISABLED
}

model Cashier {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String @unique

  status  CashierStatus @default(ACTIVE)
  session Session?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("Cashier")
}

model Session {
  id String @id @default(uuid())

  cashierId String  @unique
  cashier   Cashier @relation(fields: [cashierId], references: [id])

  activity SessionActivity[]

  chats Chat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("Session")
}

model SessionActivity {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  endedAt   DateTime?

  sessionId String
  session   Session @relation(fields: [sessionId], references: [id])
}

model Chat {
  id String @id

  fromAds Boolean

  sessionId String
  session   Session @relation(fields: [sessionId], references: [id])

  addedFunds AddFunds[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("Chat")
}

model AddFunds {
  id     String  @id @default(uuid())
  amount Decimal @db.Decimal(10, 2)

  chatId String
  chat   Chat   @relation(fields: [chatId], references: [id])

  createdAt DateTime @default(now())

  @@map("AddFunds")
}

model Lead {
  id   String @id @default(uuid())
  code String @unique

  fbc String
  fbp String

  status LEADS_STATUS @default(PENDING)

  userAgent String
  phone     String?
  expiresAt DateTime
  matchedAt DateTime?

  createdAt DateTime @default(now())
  updateAt  DateTime @updatedAt
}

enum LEADS_STATUS {
  PENDING
  CONTACTED
  CONVERTED
  EXPIRED
}
