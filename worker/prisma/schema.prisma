generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(uuid())
  name     String
  username String @unique
  password String

  role Role

  admin   Admin?
  cashier Cashier?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("User")
}

model Admin {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("Admin")
}

model Cashier {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String @unique

  sessionName               String? @unique
  whatsappPhoneNumber       String?
  whatsappLinkRefreshCount  Int     @default(0)
  whatsappLinkUpdatedAt     DateTime?
  status                    CashierStatus     @default(ACTIVE)
  activity    SessionActivity[]
  chat        Chat[]

  landings CashierLanding[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("Cashier")
}

model SessionActivity {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  endedAt   DateTime?

  cashierId String  @map("cashierId")
  cashier   Cashier @relation(fields: [cashierId], references: [id])
}

model Chat {
  id      String  @id @default(uuid())
  phone   String
  fromAds Boolean

  cashierId String  @map("cashierId")
  cashier   Cashier @relation(fields: [cashierId], references: [id])

  addedFunds AddFunds[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("Chat")
}

model AddFunds {
  id          String  @id @default(uuid())
  userName    String
  phoneNumber String
  amount      Decimal @db.Decimal(10, 2)

  chatId String
  chat   Chat   @relation(fields: [chatId], references: [id])

  createdAt DateTime @default(now())

  @@map("AddFunds")
}

model Lead {
  id   String @id @default(uuid())
  code String @unique

  fbc String
  fbp String

  status LEADS_STATUS @default(PENDING)

  userAgent   String
  phone       String?
  expiresAt   DateTime
  matchedAt   DateTime?
  convertedAt DateTime?

  createdAt DateTime @default(now())
  updateAt  DateTime @updatedAt

  @@index([phone])
}

model Landing {
  id String @id @default(uuid())

  url             String
  metaPixelId     String
  metaAccessToken String
  status          LandingStatus @default(ACTIVE)

  cashiers CashierLanding[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CashierLanding {
  cashierId String
  cashier   Cashier @relation(fields: [cashierId], references: [id])

  landingId String
  landing   Landing @relation(fields: [landingId], references: [id])

  @@id([cashierId, landingId])
  @@index([cashierId])
  @@index([landingId])
}

model ProcessedJob {
  id          String   @id @default(uuid())
  jobKey      String   @unique
  source      String
  processedAt DateTime @default(now())
}

enum CashierStatus {
  ACTIVE
  DISABLED
}

enum Role {
  CASHIER
  ADMIN
}

enum LandingStatus {
  ACTIVE
  DISABLED
}

enum LEADS_STATUS {
  PENDING
  CONTACTED
  CONVERTED
  EXPIRED
}
