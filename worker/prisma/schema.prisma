generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(uuid())
  name          String
  username      String         @unique
  password      String
  role          Role
  admin         Admin?
  cashier       Cashier?
  refreshTokens RefreshToken[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("User")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("RefreshToken")
}

model Admin {
  id        String      @id @default(uuid())
  user      User        @relation(fields: [userId], references: [id])
  userId    String      @unique
  status    AdminStatus @default(ACTIVE)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("Admin")
}

model Cashier {
  id          String            @id @default(uuid())
  user        User              @relation(fields: [userId], references: [id])
  userId      String            @unique
  maxSessions Int               @default(1)
  status      CashierStatus     @default(ACTIVE)
  activity    SessionActivity[]
  leads       Lead[]
  sessions    WhatsappSession[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("Cashier")
}

model SessionActivity {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  endedAt   DateTime?
  cashierId String    @map("cashierId")
  cashier   Cashier   @relation(fields: [cashierId], references: [id])
}

model Lead {
  id          String       @id @default(uuid())
  code        String       @unique
  adCode      String?
  fbc         String
  fbp         String
  metaPixelId String
  status      LeadStatus   @default(NOT_CONTACTED)
  userAgent   String
  phone       String?
  cashierId   String?
  cashier     Cashier?     @relation(fields: [cashierId], references: [id])
  contactedAt DateTime?
  createdAt   DateTime     @default(now())
  updateAt    DateTime     @updatedAt
  conversions Conversion[]

  @@index([phone])
  @@index([cashierId, status, contactedAt])
}

model Conversion {
  id        String   @id @default(uuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  amount    Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  @@index([leadId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model Landing {
  id              String                   @id @default(uuid())
  url             String
  metaPixelId     String                   @unique
  metaAccessToken String
  status          LandingStatus            @default(ACTIVE)
  sessions        WhatsappSessionLanding[]
  fallbackPhones  LandingFallbackPhone[]
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
}

model LandingFallbackPhone {
  id        String   @id @default(uuid())
  landingId String
  landing   Landing  @relation(fields: [landingId], references: [id], onDelete: Cascade)
  phone     String
  label     String?
  order     Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([landingId, phone])
  @@index([landingId])
}

model WhatsappSession {
  id                  String                   @id @default(uuid())
  cashierId           String
  cashier             Cashier                  @relation(fields: [cashierId], references: [id])
  sessionName         String                   @unique
  whatsappPhoneNumber String?
  refreshCount        Int                      @default(0)
  lastRefreshAt       DateTime?
  landings            WhatsappSessionLanding[]
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@index([cashierId])
  @@map("WhatsappSession")
}

model WhatsappSessionLanding {
  sessionId String
  session   WhatsappSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  landingId String
  landing   Landing         @relation(fields: [landingId], references: [id], onDelete: Cascade)

  @@id([sessionId, landingId])
  @@index([sessionId])
  @@index([landingId])
  @@map("WhatsappSessionLanding")
}

model ProcessedJob {
  id          String   @id @default(uuid())
  jobKey      String   @unique
  source      String
  processedAt DateTime @default(now())
}

enum CashierStatus {
  ACTIVE
  DISABLED
}

enum AdminStatus {
  ACTIVE
  DISABLED
}

enum Role {
  CASHIER
  ADMIN
  SUPER_ADMIN
}

enum LandingStatus {
  ACTIVE
  DISABLED
}

enum LeadStatus {
  NOT_CONTACTED
  CONTACTED
  CONVERTED
}
