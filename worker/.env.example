# Worker environment variables -- copy to .env and fill in your values.

# --- Server ---------------------------------------------------------------
PORT=3002
LOG_LEVEL=info

# --- Database -------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/onlylemon

# --- BullMQ / Redis -------------------------------------------------------
BULLMQ_REDIS_URL=redis://localhost:6379
BULLMQ_QUEUE_NAME=inbound
WORKER_CONCURRENCY=5

# --- Auth / JWT -----------------------------------------------------------
JWT_SECRET=<min-16-char-secret>

# Required -- must be at least 32 characters. Used to sign refresh tokens
# with a separate secret so a leaked access-token key cannot forge refresh tokens.
JWT_REFRESH_SECRET=<min-32-char-secret>

# Optional -- access token lifetime. Default: 7d. Allowed range: [5m, 30d].
# Examples: 15m, 2h, 7d, 30d
JWT_ACCESS_EXPIRES=7d

# Optional -- refresh token lifetime in days. Default: 30. Range: [1, 90].
JWT_REFRESH_EXPIRES_DAYS=30

# --- CORS -----------------------------------------------------------------
CORS_ORIGIN=*

# --- WAHA (WhatsApp HTTP API) ---------------------------------------------
WAHA_API_KEY=<your-waha-api-key>
WAHA_BASE_URL=http://localhost:3000
WAHA_WEBHOOK_URL=http://localhost:3002/webhook
WAHA_WEBHOOK_EVENTS=message
WAHA_WEBHOOK_TOKEN_HEADER=x-webhook-token
WAHA_WEBHOOK_TOKEN_VALUE=<your-webhook-token>

# --- Meta (optional) ------------------------------------------------------
META_PIXEL_ID=
META_ACCESS_TOKEN=
META_API_VERSION=v21.0

# --- Leads ----------------------------------------------------------------
LEADS_CODE_TTL_HOURS=24
