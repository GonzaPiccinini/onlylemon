{$DASHBOARD_DOMAIN} {
    encode zstd gzip

    # SSE: deshabilitar buffering para Server-Sent Events
    handle /api/realtime* {
        reverse_proxy worker:4000 {
            flush_interval -1
        }
    }

    # SPA del dashboard
    handle {
        reverse_proxy dashboard:80
    }

    # Embed loader público (servido por el worker en la raíz)
    handle /embed/* {
        reverse_proxy worker:4000
    }

    # Altcha challenge público (servido por el worker en la raíz)
    handle /altcha/* {
        reverse_proxy worker:4000
    }

    # API del worker
    handle /api/* {
        reverse_proxy worker:4000
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Frame-Options DENY
        X-Content-Type-Options nosniff
        Referrer-Policy strict-origin-when-cross-origin
        Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; connect-src 'self' wss://{$DASHBOARD_DOMAIN} https://{$DASHBOARD_DOMAIN}; font-src 'self' data:"
        -Server
    }
}
