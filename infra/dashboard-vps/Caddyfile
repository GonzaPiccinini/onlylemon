app.onlylemon.app {
    encode zstd gzip

    # API del worker
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy worker:4000
    }

    # SSE: deshabilitar buffering para Server-Sent Events
    handle /api/realtime* {
        uri strip_prefix /api
        reverse_proxy worker:4000 {
            flush_interval -1
        }
    }

    # SPA del dashboard
    handle {
        reverse_proxy dashboard:80
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Frame-Options DENY
        X-Content-Type-Options nosniff
        Referrer-Policy strict-origin-when-cross-origin
        Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' wss://app.onlylemon.app https://app.onlylemon.app; font-src 'self' data:"
        -Server
    }
}
