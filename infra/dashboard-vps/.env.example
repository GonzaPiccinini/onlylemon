# ── Postgres ─────────────────────────────────────────────────
POSTGRES_PASSWORD=

# ── Redis (en VPS1, via Tailscale) ───────────────────────────
REDIS_PASSWORD=
# IP privada del WAHA-VPS en la red Tailscale (tailscale ip -4 en WAHA-VPS)
WAHA_VPS_TS_IP=100.x.x.x

# ── Worker ───────────────────────────────────────────────────
BULLMQ_QUEUE_NAME=inbound
WORKER_CONCURRENCY=5
LEADS_CODE_TTL_HOURS=48
JWT_SECRET=
CORS_ORIGIN=https://app.onlylemon.app
LOG_LEVEL=info

# ── WAHA ─────────────────────────────────────────────────────
WAHA_API_KEY=
WAHA_BASE_URL=https://waha.onlylemon.app
# URL del worker para recibir eventos de sesión de WAHA
WAHA_WEBHOOK_URL=https://app.onlylemon.app/api/whatsapp/events/session-status
WAHA_WEBHOOK_TOKEN_HEADER=X-Waha-Webhook-Token
WAHA_WEBHOOK_TOKEN_VALUE=

# ── Meta Pixel (opcional) ─────────────────────────────────────
META_PIXEL_ID=
META_ACCESS_TOKEN=

# ── Dashboard (build arg) ─────────────────────────────────────
VITE_API_BASE_URL=https://app.onlylemon.app/api

# ── Grafana Cloud ─────────────────────────────────────────────
GRAFANA_PROM_URL=https://prometheus-prod-XX.grafana.net/api/prom/push
GRAFANA_PROM_USER=
GRAFANA_PROM_TOKEN=
GRAFANA_LOKI_URL=https://logs-prod-XX.grafana.net/loki/api/v1/push
GRAFANA_LOKI_USER=
GRAFANA_LOKI_TOKEN=
