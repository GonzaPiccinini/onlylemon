# ── Imagen ───────────────────────────────────────────────────
# Por tenant: ghcr.io/gonzapiccinini/onlylemon-<slug>
IMAGE_PREFIX=
IMAGE_TAG=

# ── Dominio (interpolado por el Caddyfile) ────────────────────
DASHBOARD_DOMAIN=

# ── Postgres ─────────────────────────────────────────────────
POSTGRES_PASSWORD=

# ── Redis (en WAHA-VPS, via Tailscale) ───────────────────────
REDIS_PASSWORD=
# IP privada del WAHA-VPS en la red Tailscale (tailscale ip -4 en WAHA-VPS)
WAHA_VPS_TS_IP=

# ── Worker ───────────────────────────────────────────────────
BULLMQ_QUEUE_NAME=
WORKER_CONCURRENCY=
LEADS_CODE_TTL_HOURS=
JWT_SECRET=
JWT_REFRESH_SECRET=
CORS_ORIGIN=
LOG_LEVEL=
OPENAI_API_KEY=
OPENAI_MODEL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_REGION=
META_DRY_RUN=
AUTO_OCR_DAILY_LIMIT=

# ── WAHA (consumido por el worker) ────────────────────────────
WAHA_API_KEY=
WAHA_BASE_URL=
# URL que el worker le pasa a WAHA para que postee eventos.
# WAHA y gateway corren en la misma red docker de WAHA-VPS, por eso es interna.
WAHA_WEBHOOK_URL=http://gateway:3000/api/webhook
WAHA_WEBHOOK_TOKEN_HEADER=
WAHA_WEBHOOK_TOKEN_VALUE=
WAHA_WEBHOOK_EVENTS=

# ── Dashboard (build arg) ─────────────────────────────────────
VITE_API_BASE_URL=

# ── Grafana Cloud ─────────────────────────────────────────────
GRAFANA_PROM_URL=
GRAFANA_PROM_USER=
GRAFANA_PROM_TOKEN=
GRAFANA_LOKI_URL=
GRAFANA_LOKI_USER=
GRAFANA_LOKI_TOKEN=