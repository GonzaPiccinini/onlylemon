# ── Postgres ─────────────────────────────────────────────────
POSTGRES_PASSWORD=

# ── Redis (en VPS1, via Tailscale) ───────────────────────────
REDIS_PASSWORD=
# IP privada del WAHA-VPS en la red Tailscale (tailscale ip -4 en WAHA-VPS)
WAHA_VPS_TS_IP=

# ── Worker ───────────────────────────────────────────────────
BULLMQ_QUEUE_NAME=
WORKER_CONCURRENCY=
LEADS_CODE_TTL_HOURS=
JWT_SECRET=
JWT_REFRESH_SECRET
CORS_ORIGIN=
LOG_LEVEL=

# ── WAHA ─────────────────────────────────────────────────────
WAHA_API_KEY=
WAHA_BASE_URL=
# URL del worker para recibir eventos de sesión de WAHA
WAHA_WEBHOOK_URL=
WAHA_WEBHOOK_TOKEN_HEADER=
WAHA_WEBHOOK_TOKEN_VALUE=
WAHA_WEBHOOK_EVENTS=

# ── Dashboard (build arg) ─────────────────────────────────────
VITE_API_BASE_URL=

# ── Grafana Cloud ─────────────────────────────────────────────
GRAFANA_PROM_URL=
GRAFANA_PROM_USER=
GRAFANA_PROM_TOKEN=
GRAFANA_LOKI_URL=
GRAFANA_LOKI_USER=
