# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=

# ── Tailscale ────────────────────────────────────────────────
# IP privada del WAHA-VPS en la red Tailscale (tailscale ip -4)
WAHA_VPS_TS_IP=100.x.x.x

# ── Gateway ──────────────────────────────────────────────────
WEBHOOK_TOKEN_HEADER=X-Webhook-Token
WEBHOOK_TOKEN_VALUE=
BULLMQ_QUEUE_NAME=inbound
CORS_ALLOWED_ORIGINS=https://app.onlylemon.app
MAX_PAYLOAD_BYTES=1048576
QUEUE_MAX_BACKLOG=10000
QUEUE_DEGRADED_BACKLOG=5000
LOG_LEVEL=info

# ── WAHA ─────────────────────────────────────────────────────
WAHA_API_KEY=
# URL donde WAHA enviará los webhooks (endpoint público del gateway)
WAHA_WEBHOOK_TARGET_URL=https://api.onlylemon.app/webhook
# Hash generado con: docker run --rm caddy:2-alpine caddy hash-password --plaintext "tu_password"
WAHA_BASIC_AUTH_HASH=

# ── Grafana Cloud ─────────────────────────────────────────────
GRAFANA_PROM_URL=https://prometheus-prod-XX.grafana.net/api/prom/push
GRAFANA_PROM_USER=
GRAFANA_PROM_TOKEN=
GRAFANA_LOKI_URL=https://logs-prod-XX.grafana.net/loki/api/v1/push
GRAFANA_LOKI_USER=
GRAFANA_LOKI_TOKEN=
