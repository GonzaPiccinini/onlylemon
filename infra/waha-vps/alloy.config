// ============================================================
// Grafana Alloy config — VPS1 (gateway)
// Scrape métricas de gateway y shipea logs de todos los containers
// ============================================================

prometheus.scrape "gateway" {
  targets = [
    {"__address__" = "gateway:3000", "job" = "gateway"},
  ]
  forward_to    = [prometheus.remote_write.grafana.receiver]
  metrics_path  = "/metrics"
  scrape_interval = "30s"
}

prometheus.remote_write "grafana" {
  endpoint {
    url = env("GRAFANA_PROM_URL")
    basic_auth {
      username = env("GRAFANA_PROM_USER")
      password = env("GRAFANA_PROM_TOKEN")
    }
  }
  external_labels = {
    vps = "vps1",
    env = "production",
  }
}

discovery.docker "containers" {
  host             = "unix:///var/run/docker.sock"
  refresh_interval = "15s"
}

loki.source.docker "containers" {
  host          = "unix:///var/run/docker.sock"
  targets       = discovery.docker.containers.targets
  forward_to    = [loki.write.grafana.receiver]
  relabel_rules = loki.relabel.docker_labels.rules
}

loki.relabel "docker_labels" {
  forward_to = []
  rule {
    source_labels = ["__meta_docker_container_name"]
    target_label  = "container"
    regex         = "/(.*)"
    replacement   = "$1"
  }
  rule {
    source_labels = ["__meta_docker_compose_service"]
    target_label  = "service"
  }
}

loki.write "grafana" {
  endpoint {
    url = env("GRAFANA_LOKI_URL")
    basic_auth {
      username = env("GRAFANA_LOKI_USER")
      password = env("GRAFANA_LOKI_TOKEN")
    }
  }
  external_labels = {
    vps = "vps1",
    env = "production",
  }
}
